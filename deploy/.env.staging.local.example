# =====================================================================
# HomeChef Pro - .env para STAGING LOCAL (prod-mode)
# =====================================================================
# Copia este archivo a .env.staging.local y rellena con valores reales:
#     cp deploy/.env.staging.local.example deploy/.env.staging.local
#
# .env.staging.local NO se commitea (ya en .gitignore via patron .env.*.local).
#
# Generar secretos antes de pegarlos aqui:
#     POSTGRES_PASSWORD=$(openssl rand -base64 24)
#     REDIS_PASSWORD=$(openssl rand -base64 24)
#     JWT_SIGNING_KEY=$(openssl rand -base64 64)
#     BOOTSTRAP_ADMIN_PASSWORD=$(openssl rand -base64 18)
# (En Windows PowerShell:
#     [Convert]::ToBase64String((1..24 | %{Get-Random -Max 256}))
# o usar git-bash / WSL.)
#
# Uso:
#     cd deploy
#     docker compose --env-file .env.staging.local -f docker-compose.yml -f docker-compose.staging.yml up -d
# =====================================================================

# --- PostgreSQL ---
# IMPORTANTE: el password NO debe contener "homechef_dev" (Program.cs F-06
# rechaza el container al startup si lo hace).
POSTGRES_DB=homechef
POSTGRES_USER=homechef
POSTGRES_PASSWORD=REPLACE-ME-with-openssl-rand-base64-24
POSTGRES_PORT=5432

# --- Redis ---
# Password requerido en staging/prod (docker-compose.staging.yml lo exige).
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE-ME-with-openssl-rand-base64-24

# --- API ---
API_PORT=8080

# --- JWT ---
# Generar con: openssl rand -base64 64
# Minimo 32 caracteres (validado en startup).
JWT_SIGNING_KEY=REPLACE-ME-with-openssl-rand-base64-64-min-32-chars-for-validation-to-pass
JWT_ISSUER=HomeChefPro
JWT_AUDIENCE=HomeChefPro.Clients

# --- AllowedHosts (F-13) ---
# En staging local: localhost. En prod real: tu(s) dominio(s).
ALLOWED_HOSTS=localhost

# --- CORS (D-01 audit Pasada D) ---
# Debe coincidir con los puertos de las apps Flutter.
CORS_ORIGIN_0=http://localhost:8090
CORS_ORIGIN_1=http://localhost:8091
CORS_ORIGIN_2=http://localhost:8092

# --- Bootstrap admin (F-07) ---
# Password NO puede ser "demo1234", "admin", "password" (rechazado en startup).
# Generar con: openssl rand -base64 18
BOOTSTRAP_ADMIN_EMAIL=admin@homechef.local
BOOTSTRAP_ADMIN_PASSWORD=REPLACE-ME-with-openssl-rand-base64-18
BOOTSTRAP_ADMIN_FULLNAME=Admin Staging

# --- Webhooks delivery (F-32) ---
# Si el chef piloto NO usa delivery 3rd party, dejar vacios — webhooks
# entrantes seran rechazados con 401 (RejectInvalidSignature=true por default).
DELIVERY_SECRET_YUMMY=
DELIVERY_SECRET_PEDIDOSYA=
DELIVERY_SECRET_RAPPI=
