# =====================================================================
# HomeChef Pro - Variables de entorno
# Copia este archivo a .env y rellena los valores.
# .env NUNCA debe subirse al repo.
# =====================================================================

# --- PostgreSQL ---
POSTGRES_DB=homechef
POSTGRES_USER=homechef
POSTGRES_PASSWORD=homechef_dev
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
# Solo en prod:
REDIS_PASSWORD=

# --- API ---
API_PORT=8080

# --- JWT ---
# Generar con: openssl rand -base64 48
JWT_SIGNING_KEY=change-me-to-a-long-random-string-of-at-least-32-bytes
JWT_ISSUER=HomeChefPro
JWT_AUDIENCE=HomeChefPro.Clients
