# Default: text files normalized to LF in the repo, OS-native in the working tree.
# This eliminates CRLF/LF noise across Windows/Linux/macOS contributors.
* text=auto eol=lf

# Source code — explicit LF
*.cs        text eol=lf diff=csharp
*.csproj    text eol=lf
*.sln       text eol=lf
*.slnx      text eol=lf
*.dart      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.toml      text eol=lf
*.editorconfig text eol=lf

# Config files
.gitattributes  text eol=lf
.gitignore      text eol=lf
.dockerignore   text eol=lf
Dockerfile      text eol=lf
*.dockerfile    text eol=lf

# Shell scripts MUST be LF or they break on Linux
*.sh        text eol=lf
*.bash      text eol=lf

# Windows-specific scripts MUST be CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf

# Binary — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.webp      binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.tar.gz    binary
*.tgz       binary
*.rar       binary
*.7z        binary
*.gz        binary

# Fonts
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary

# Compiled / build artifacts that shouldn't be tracked anyway, but if they slip in
*.dll       binary
*.exe       binary
*.so        binary
*.dylib     binary
*.pdb       binary
*.snk       binary
*.pfx       binary
*.cer       binary

# Flutter / Dart specific
*.lock              text eol=lf
pubspec.lock        text eol=lf
package-lock.json   text eol=lf -diff

# .NET specific lockfiles
packages.lock.json  text eol=lf -diff

# Database dumps — large, treat as binary for diff purposes but text for line endings
*.dump      binary
