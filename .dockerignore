# =====================================================================
# HomeChef Pro - .dockerignore
# =====================================================================
# Excluye artefactos locales del build context para que el build dentro
# del contenedor Linux NO arrastre rutas absolutas de Windows
# (especialmente obj/project.assets.json).
# =====================================================================

# .NET / Visual Studio
**/bin/
**/obj/
**/*.user
**/*.suo
**/.vs/
**/TestResults/
**/publish/
**/*.pdb

# NuGet locales (si Visual Studio dejó NuGet.config con paths de Windows)
**/NuGet.Config
**/nuget.config
**/.nuget/

# Flutter / Dart
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/build/
**/ios/Pods/
**/android/.gradle
**/android/local.properties

# Node
**/node_modules/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Git
.git/
.gitignore
.gitattributes

# IDE
.idea/
.vscode/

# Logs y temporales
**/*.log
**/logs/

# Secrets (nunca al contexto)
deploy/.env
deploy/.env.local
deploy/.env.*.local
**/*.pem
**/*.key
deploy/nginx/certs/*.crt
deploy/nginx/certs/*.key

# Uploads de runtime
uploads/

# Documentación que el build no necesita
*.md
docs/
design_handoff_homechef_pro/
build.log
